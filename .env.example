# Local development — copy to .env.development
APP_ENV=development
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:3000

# Vercel production — set in Vercel Dashboard → Settings → Environment Variables
# IMPORTANT: NEXT_PUBLIC_API_URL must be /api (relative proxy path), NOT the Render backend URL
# APP_ENV=production
# NEXT_PUBLIC_API_URL=/api
# API_PROXY_TARGET=https://your-backend.onrender.com
